{% extends 'base.html.twig' %}

{% block title %}Klienci - CRM{% endblock %}

{% set status_labels = {
    'prospect': 'Prospekt',
    'demo': 'Demo',
    'implementing': 'Wdrozenie',
    'active': 'Aktywny',
    'resigned': 'Rezygnacja',
    'deleted': 'Usuniety'
} %}

{% set status_colors = {
    'prospect': 'badge-blue',
    'demo': 'badge-yellow',
    'implementing': 'bg-purple-100 text-purple-800 px-2.5 py-0.5 rounded-full text-xs font-medium',
    'active': 'badge-green',
    'resigned': 'badge-red',
    'deleted': 'badge-gray'
} %}

{% set tabs = [
    {key: null, label: 'Wszyscy'},
    {key: 'prospect', label: 'Prospekci'},
    {key: 'demo', label: 'Demo'},
    {key: 'clients', label: 'Klienci'},
    {key: 'resigned', label: 'Rezygnacja'}
] %}

{% block body %}
<div>
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900">Klienci</h2>
        <a href="{{ path('client_new') }}" class="btn btn-primary">Dodaj klienta</a>
    </div>

    {# Status filter tabs #}
    <div class="flex border-b border-gray-200 mb-4" role="tablist">
        {% for tab in tabs %}
            {% set is_active = current_status == tab.key %}
            <a href="{{ path('client_list', tab.key ? {status: tab.key} : {}) }}"
               role="tab"
               class="px-4 py-2 text-sm font-medium border-b-2 transition-colors {{ is_active ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }}">
                {{ tab.label }}
            </a>
        {% endfor %}
    </div>

    {# Search #}
    <div class="mb-4">
        <form method="get" action="{{ path('client_list') }}" class="flex gap-2">
            {% if current_status %}
                <input type="hidden" name="status" value="{{ current_status }}">
            {% endif %}
            <input type="text" name="search" value="{{ search }}" placeholder="Szukaj klientow..." class="input flex-1">
            <button type="submit" class="btn btn-primary">Szukaj</button>
        </form>
    </div>

    {# Table #}
    <div class="card p-0">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Firma</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">NIP</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Kontakt</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Miasto</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Data</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {% if clients|length == 0 %}
                        <tr>
                            <td colspan="7" class="px-6 py-8 text-center text-gray-500">Brak danych</td>
                        </tr>
                    {% else %}
                        {% for client in clients %}
                            <tr class="cursor-pointer hover:bg-gray-50" onclick="window.location='{{ path('client_show', {id: client.id}) }}'">
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ client.companyName }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ client.taxId }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ client.contactPerson }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ client.email }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ client.city }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    <span class="{{ status_colors[client.status] ?? 'badge-gray' }}">
                                        {{ status_labels[client.status] ?? client.status }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                    {{ client.createdAt ? client.createdAt|date('d.m.Y') : '-' }}
                                </td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>

        {# Pagination #}
        {% include 'components/_pagination.html.twig' with {
            page: page,
            limit: limit,
            total: total,
            pages: pages,
            route: 'client_list',
            route_params: current_status ? {status: current_status} : {}
        } %}
    </div>
</div>
{% endblock %}
