<div id="confirm-dialog" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-lg shadow-xl p-6 max-w-md w-full mx-4">
        <h3 id="confirm-title" class="text-lg font-semibold text-gray-900 mb-2"></h3>
        <p id="confirm-message" class="text-sm text-gray-600 mb-6"></p>
        <div class="flex justify-end gap-3">
            <button id="confirm-cancel" class="btn btn-secondary">Anuluj</button>
            <button id="confirm-ok" class="btn btn-danger">Potwierdz</button>
        </div>
    </div>
</div>
