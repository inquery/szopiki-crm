<header class="bg-white shadow-sm border-b border-gray-200 px-6 py-4 flex items-center justify-between">
    <div class="text-sm text-gray-600">
        Mini CRM
    </div>
    <div class="flex items-center gap-4">
        {% if app.user %}
            <span class="text-sm text-gray-700">{{ app.user.firstName }} {{ app.user.lastName }}</span>
            <a href="{{ path('app_logout') }}" class="text-sm text-red-600 hover:text-red-800 transition-colors">
                Wyloguj
            </a>
        {% endif %}
    </div>
</header>
