{% extends 'base.html.twig' %}

{% block title %}Pipeline - CRM{% endblock %}

{% set stages = [
    {key: 'lead', label: 'Lead', color: 'border-blue-400 bg-blue-50'},
    {key: 'proposal', label: 'Propozycja', color: 'border-yellow-400 bg-yellow-50'},
    {key: 'negotiation', label: 'Negocjacje', color: 'border-purple-400 bg-purple-50'},
    {key: 'won', label: 'Wygrana', color: 'border-green-400 bg-green-50'},
    {key: 'lost', label: 'Przegrana', color: 'border-red-400 bg-red-50'}
] %}

{% block body %}
<div>
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900">Pipeline</h2>
        <a href="{{ path('deal_list') }}" class="btn btn-secondary">Lista</a>
    </div>
    <div class="grid grid-cols-5 gap-4">
        {% for stage in stages %}
            {% set stage_deals = pipeline[stage.key] ?? [] %}
            <div class="rounded-lg border-t-4 {{ stage.color }} p-3">
                <h3 class="text-sm font-semibold mb-3">{{ stage.label }} ({{ stage_deals|length }})</h3>
                <div class="space-y-2">
                    {% for deal in stage_deals %}
                        <a href="{{ path('deal_show', {id: deal.id}) }}" class="block bg-white p-3 rounded shadow-sm hover:shadow-md transition-shadow text-xs">
                            <p class="font-medium text-gray-900 truncate">{{ deal.title }}</p>
                            <p class="text-gray-500">{{ deal.client ? deal.client.companyName : '' }}</p>
                            <p class="text-gray-700 font-semibold mt-1">{{ deal.value|number_format(0, ',', ' ') }} {{ deal.currency ?? 'PLN' }}</p>
                        </a>
                    {% endfor %}
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
