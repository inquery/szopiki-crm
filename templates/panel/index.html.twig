{% extends 'base.html.twig' %}

{% block title %}Panele - CRM{% endblock %}

{% block body %}
<div>
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900">Panele</h2>
        <button onclick="openPanelForm()" class="btn btn-primary">Nowy panel</button>
    </div>

    {% if panels|length > 0 %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for panel in panels %}
                <div class="card">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-lg font-semibold">{{ panel.panelType|upper }}</h3>
                        <span class="badge {{ panel.isInstalled is defined and panel.isInstalled ? 'badge-green' : 'badge-yellow' }}">
                            {{ panel.isInstalled is defined and panel.isInstalled ? 'Zainstalowany' : 'Niezainstalowany' }}
                        </span>
                    </div>
                    <p class="text-sm text-gray-500 mb-2">{{ panel.panelUrl ?: 'Brak URL' }}</p>
                    {% if panel.notes %}
                        <p class="text-xs text-gray-500 mb-4">{{ panel.notes }}</p>
                    {% endif %}
                    <div class="flex gap-2">
                        {% if panel.panelUrl %}
                            <a href="{{ panel.panelUrl }}" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-secondary">Otworz panel</a>
                        {% endif %}
                        <button onclick="installPanel({{ panel.id }})" class="btn btn-sm btn-primary">Zainstaluj</button>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="card text-center py-12">
            <p class="text-gray-500 mb-4">Brak skonfigurowanych paneli</p>
            <button onclick="openPanelForm()" class="btn btn-primary">Dodaj pierwszy panel</button>
        </div>
    {% endif %}
</div>

{# Panel form modal #}
<div id="panel-modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-lg shadow-xl p-6 max-w-lg w-full mx-4 max-h-[90vh] overflow-y-auto">
        <h3 class="text-lg font-semibold mb-4">Nowy panel</h3>
        <form id="panel-form" class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="label">Typ panelu</label>
                    <select name="panel_type" class="input">
                        <option value="cpanel">cPanel</option>
                        <option value="directadmin">DirectAdmin</option>
                        <option value="plesk">Plesk</option>
                        <option value="custom">Inny</option>
                    </select>
                </div>
                <div><label class="label">URL panelu</label><input name="panel_url" class="input"></div>
                <div><label class="label">Login panelu</label><input name="panel_username" class="input"></div>
                <div><label class="label">Haslo panelu</label><input name="panel_password" type="password" class="input"></div>
            </div>
            <hr>
            <p class="text-sm font-medium text-gray-700">Dane bazy danych</p>
            <div class="grid grid-cols-2 gap-4">
                <div><label class="label">Host bazy</label><input name="database_host" class="input"></div>
                <div><label class="label">Nazwa bazy</label><input name="database_name" class="input"></div>
                <div><label class="label">Login bazy</label><input name="database_username" class="input"></div>
                <div><label class="label">Haslo bazy</label><input name="database_password" type="password" class="input"></div>
            </div>
            <div><label class="label">Notatki</label><textarea name="notes" class="input" rows="2"></textarea></div>
            <div class="flex justify-end gap-3">
                <button type="button" onclick="closePanelForm()" class="btn btn-secondary">Anuluj</button>
                <button type="submit" class="btn btn-primary">Zapisz</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
function openPanelForm() { document.getElementById('panel-modal').classList.remove('hidden'); }
function closePanelForm() { document.getElementById('panel-modal').classList.add('hidden'); document.getElementById('panel-form').reset(); }

async function installPanel(id) {
    try {
        await App.post('/api/panel/install/' + id);
        App.success('Instalacja uruchomiona');
    } catch (err) {
        App.error(err.message || 'Instalacja nie jest jeszcze zaimplementowana');
    }
}

document.getElementById('panel-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    try {
        await App.post('/api/panel/config', App.formData(e.target));
        App.success('Konfiguracja panelu zapisana');
        window.location.reload();
    } catch (err) { App.error(err.message || 'Blad zapisu'); }
});
</script>
{% endblock %}
