{% extends 'base.html.twig' %}

{% block title %}Uzytkownicy - CRM{% endblock %}

{% block body %}
<div>
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900">Uzytkownicy</h2>
        <button onclick="openUserForm()" class="btn btn-primary">Dodaj uzytkownika</button>
    </div>
    <div class="card p-0">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Imie</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nazwisko</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Telefon</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">2FA</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"></th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {% for user in users %}
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ user.email }}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ user.firstName }}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ user.lastName }}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ user.phone }}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <span class="{{ user.twoFactorEnabled ? 'badge-green' : 'badge-gray' }}">{{ user.twoFactorEnabled ? 'Tak' : 'Nie' }}</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <span class="{{ user.isActive ? 'badge-green' : 'badge-red' }}">{{ user.isActive ? 'Aktywny' : 'Nieaktywny' }}</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <div class="flex gap-1">
                                    <button onclick="editUser({{ user.id }}, '{{ user.email }}', '{{ user.firstName }}', '{{ user.lastName }}', '{{ user.phone }}', {{ 'ROLE_ADMIN' in user.roles ? 'true' : 'false' }}, {{ user.twoFactorEnabled ? 'true' : 'false' }})" class="btn btn-sm btn-secondary">Edytuj</button>
                                    {% if user.isActive %}
                                        <button onclick="deactivateUser({{ user.id }})" class="btn btn-sm btn-danger">Dezaktywuj</button>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{# User form modal #}
<div id="user-modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-lg shadow-xl p-6 max-w-lg w-full mx-4">
        <h3 id="user-modal-title" class="text-lg font-semibold mb-4">Nowy uzytkownik</h3>
        <form id="user-form" class="space-y-4">
            <input type="hidden" name="_edit_id" id="user-edit-id" value="">
            <div class="grid grid-cols-2 gap-4">
                <div><label class="label">Email *</label><input name="email" type="email" class="input" required></div>
                <div><label class="label">Haslo <span id="pwd-hint"></span></label><input name="password" type="password" class="input" id="user-password"></div>
                <div><label class="label">Imie *</label><input name="first_name" class="input" required></div>
                <div><label class="label">Nazwisko *</label><input name="last_name" class="input" required></div>
                <div><label class="label">Telefon (do 2FA)</label><input name="phone" class="input" placeholder="+48..."></div>
                <div>
                    <label class="label">Rola</label>
                    <select name="role" class="input" id="user-role">
                        <option value="user">Uzytkownik</option>
                        <option value="admin">Administrator</option>
                    </select>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <input type="checkbox" id="user-2fa" name="two_factor_enabled">
                <label for="user-2fa" class="text-sm text-gray-700">Wlacz weryfikacje dwuetapowa (SMS)</label>
            </div>
            <div class="flex justify-end gap-3">
                <button type="button" onclick="closeUserForm()" class="btn btn-secondary">Anuluj</button>
                <button type="submit" class="btn btn-primary">Zapisz</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
let currentEditId = null;

function openUserForm() {
    currentEditId = null;
    document.getElementById('user-edit-id').value = '';
    document.getElementById('user-modal-title').textContent = 'Nowy uzytkownik';
    document.getElementById('pwd-hint').textContent = '*';
    document.getElementById('user-password').required = true;
    document.getElementById('user-form').reset();
    document.getElementById('user-modal').classList.remove('hidden');
}

function editUser(id, email, firstName, lastName, phone, isAdmin, twoFactor) {
    currentEditId = id;
    document.getElementById('user-edit-id').value = id;
    document.getElementById('user-modal-title').textContent = 'Edytuj uzytkownika';
    document.getElementById('pwd-hint').textContent = '(puste = bez zmian)';
    document.getElementById('user-password').required = false;
    document.querySelector('[name="email"]').value = email;
    document.querySelector('[name="first_name"]').value = firstName;
    document.querySelector('[name="last_name"]').value = lastName;
    document.querySelector('[name="phone"]').value = phone;
    document.getElementById('user-role').value = isAdmin ? 'admin' : 'user';
    document.getElementById('user-2fa').checked = twoFactor;
    document.getElementById('user-modal').classList.remove('hidden');
}

function closeUserForm() {
    document.getElementById('user-modal').classList.add('hidden');
}

async function deactivateUser(id) {
    const ok = await App.confirm('Dezaktywuj uzytkownika', 'Czy na pewno?');
    if (!ok) return;
    try {
        await App.delete('/api/users/' + id);
        App.success('Uzytkownik dezaktywowany');
        window.location.reload();
    } catch (err) { App.error('Blad dezaktywacji'); }
}

document.getElementById('user-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = App.formData(e.target);
    const editId = data._edit_id;
    delete data._edit_id;

    data.roles = data.role === 'admin' ? ['ROLE_ADMIN'] : ['ROLE_USER'];
    delete data.role;
    data.two_factor_enabled = document.getElementById('user-2fa').checked;

    if (editId && !data.password) delete data.password;

    try {
        if (editId) {
            await App.put('/api/users/' + editId, data);
            App.success('Uzytkownik zaktualizowany');
        } else {
            await App.post('/api/users', data);
            App.success('Uzytkownik dodany');
        }
        window.location.reload();
    } catch (err) { App.error(err.message || 'Blad'); }
});
</script>
{% endblock %}
